pipeline {
    agent any

    environment{
        GOPATH = "${WORKSPACE}/.go"
        GOCACHE = "${WORKSPACE}/.cache"
    }

    stages{
       stage('Unit Tests - Backend'){
            agent{
                docker{
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                }
            }
            steps{
                dir('bugtracker-backend'){
                    sh 'go mode download'
                    sh 'go test -v ./...'
                }
            }
       }
       stage('Unit Tests - Frontend'){
            agent{
                docker{
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('bugtracker-frontend'){
                    sh '''
                        npm ci
                        npm test
                    '''
                }
            }
       }
    }
}
