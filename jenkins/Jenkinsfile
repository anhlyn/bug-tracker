pipeline {
    agent{
        docker{
            image 'golang:1.21-alpine'
        }
    }

    environment{
        GOCACHE = "${WORKSPACE}/.cache"
    }

    stages{
        stage('Check go version'){
            steps{
               sh 'go version' 
            }
        }
        stage('Download dependencies'){
            steps{
                dir('bugtracker-backend'){
                    sh 'go mod download'
               }
            }
        }
        stage('Running unit test'){
            steps{
                dir('bugtracker-backend'){
                    sh 'go test ./... -v'
                }
            }
        }
    }
}
